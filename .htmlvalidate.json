{
	"extends": ["html-validate:document"],
	"rules": {
		"no-dup-attr": "error",
		"no-dup-id": "error",
		"close-attr": "error",
		"close-order": "error",
		"missing-doctype": "error",

		"element-required-attributes": "off",
		"require-sri": "off",
		"heading-level": "off",
		"input-missing-label": "off"
	}
}
